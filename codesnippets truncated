			SequenceRecordUnit &record = sequenceRecordsforTest.Records[rec_idx];
			uint32_t collision_count = 0;
			for(uint32_t hash_idx = 0; hash_idx < N_hash; hash_idx++){
				if(rec_idx % 200 == 0 && hash_idx == 0){
					printf("Processing sequence %u / %u\n", rec_idx, N_seq);
				}

				std::vector<uint32_t> and_flags = std::vector<uint32_t>(or_param, 0); 
				for(uint32_t or_i = 0; or_i < or_param; or_i++){
					and_flags[or_i] = 1;
					for(uint32_t and_i = 0; and_i < and_param; and_i++){
						andor_seeds[or_i * and_param + and_i] = HashSeed + hash_idx + (or_i * and_param + and_i)*1337;
						if(hinfo->hasUniverseVectorOptimisation() == true){
							UnionBitVectorsStruct unionBitVectors = CreateUnionBitVectors(record.SeqASCIIOrg, record.SeqASCIIMut, common_params.tokenlength);

							// print the sequences
							// std::cout << record.SeqASCIIOrg << "\n";
							// std::cout << record.SeqASCIIMut << "\n";
							// std::cout << "Universe: ";
							// for (auto& k : unionBitVectors.universe) std::cout << k << " ";
							// std::cout << "\nVec A:    ";
							// for (char v : unionBitVectors.vec_a) std::cout << v << "   ";
							// std::cout << "\nVec B:    ";
							// for (char v : unionBitVectors.vec_b) std::cout << v << "   ";
							// std::cout << std::endl;
							
							// printf("Union vector sizes: VecA = %zu, VecB = %zu, Universe = %zu\n", unionBitVectors.vec_a.size(), unionBitVectors.vec_b.size(), unionBitVectors.universe.size());

							// std::cout<< unionBitVectors.vec_a[0] << std::endl;

							// printf("Union vector sizes: VecA = %zu, VecB = %zu, Universe = %zu\n", unionBitVectors.vec_a.size(), unionBitVectors.vec_b.size(), unionBitVectors.universe.size());

							hash(unionBitVectors.vec_a.data(), unionBitVectors.vec_a.size(), andor_seeds[or_i * and_param + and_i], &hash_val_org[or_i * and_param + and_i]);
							hash(unionBitVectors.vec_b.data(), unionBitVectors.vec_b.size(), andor_seeds[or_i * and_param + and_i], &hash_val_mut[or_i * and_param + and_i]);
						}
						else{
							hash((const uint8_t*)record.SeqASCIIOrg.c_str(), record.OriginalLength, andor_seeds[or_i * and_param + and_i], &hash_val_org[or_i * and_param + and_i]);
							hash((const uint8_t*)record.SeqASCIIMut.c_str(), record.MutatedLength, andor_seeds[or_i * and_param + and_i], &hash_val_mut[or_i * and_param + and_i]);
						}
					}
					for(uint32_t i = 0; i < and_param; i++){
						if(hash_val_org[or_i * and_param + i] != hash_val_mut[or_i * and_param + i]){
							and_flags[or_i] = 0;
							break;
						}
					}
				}
				//AND-ORING
				bool flag = 0;
				for(uint32_t i = 0; i < or_param; i++){
					if(and_flags[i] == 1){
						flag = 1;
						break;
					}
				}
				collision_count += flag;
			}
			double avg_collision = static_cast<double>(collision_count) / static_cast<double>(N_hash);
			if (rec_idx == N_seq - 1)
				out_file << avg_collision << "\n";
			else
				out_file << avg_collision << ",";
		}
	}

	return true;
}
